<?xml version="1.0" encoding="utf-8"?>
<!-- Data extraction rules for Android 12+ (API 31+) -->
<data-extraction-rules>
    <cloud-backup>
        <!-- Include grocery list data in cloud backup -->
        <include domain="sharedpref" path="grocery_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Include grocery list data in device-to-device transfer -->
        <include domain="sharedpref" path="grocery_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>
